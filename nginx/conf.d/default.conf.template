server {
    listen 80;
    server_name ${DOMAIN_NAME};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        # GHSA-9mgf-6qrf-qfvg: redirect target is the deployment-configured
        # DOMAIN_NAME, NOT the client-supplied Host header. Using $http_host
        # here made this the phishing primitive it was — an attacker curling
        # `Host: attacker.example` on port 80 got back a 301 to their site
        # from the genuine RedWire nginx. envsubst rewrites ${DOMAIN_NAME}
        # at container start (see docker-compose.prod.yml env), so the
        # target is fixed at deploy time.
        return 301 https://${DOMAIN_NAME}$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name ${DOMAIN_NAME};

    ssl_certificate /etc/letsencrypt/live/${DOMAIN_NAME}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN_NAME}/privkey.pem;

    # Use Docker's internal DNS resolver
    resolver 127.0.0.11 valid=30s;

    # Allow large file uploads (wordlists)
    client_max_body_size 200M;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Next.js HMR WebSocket (dev only)
    location /_next/webpack-hmr {
        set $frontend_url http://frontend:3000;
        proxy_pass $frontend_url;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $http_host;
    }

    location / {
        # Using a variable forces Nginx to resolve the host at runtime instead of startup
        set $frontend_url http://frontend:3000;
        proxy_pass $frontend_url;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        # Replace, don't append. $proxy_add_x_forwarded_for would let a
        # client-sent X-Forwarded-For sit at the left of the chain that
        # uvicorn's --proxy-headers middleware then trusts.
        # GHSA-xg53-8wgq-w9cw.
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Auth endpoints don't legitimately need multi-MB payloads — login
    # is JSON, TOTP is 6 digits, password reset is a token + password.
    # Global client_max_body_size is 200M (wordlist uploads elsewhere);
    # this cap kills the multipart-preamble parser DoS class flagged in
    # GHSA-cvhc-7gfq-59p3's follow-up. Cheap: python-multipart still
    # walks the preamble byte-by-byte at ~85 μs/KiB, so bounding the
    # body to 64k bounds the per-request worker cost to a few ms.
    # Route match uses `^~` prefix so this block wins over the shorter
    # /api/ location for any /api/auth/* URI without a regex scan.
    location ^~ /api/auth/ {
        client_max_body_size 64k;

        set $backend_url http://backend:8000;
        rewrite ^/api/(.*)$ /$1 break;
        proxy_pass $backend_url;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        set $backend_url http://backend:8000;
        rewrite ^/api/(.*)$ /$1 break;
        proxy_pass $backend_url;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        # Replace, don't append — see / location above for the rationale.
        # GHSA-xg53-8wgq-w9cw.
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Long timeouts for slow endpoints (local LLM inference, scanner imports).
        # Nginx's 60s default kills AI auto-suggest mid-flight. Match the backend's
        # per-call AI_REQUEST_TIMEOUT (300s) plus headroom for batched calls.
        proxy_connect_timeout  60s;
        proxy_send_timeout    600s;
        proxy_read_timeout    600s;
    }
}
