# Production Configuration
DOMAIN_NAME=redwire.yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# Database Configuration

POSTGRES_DB=redwire
POSTGRES_USER=redwire
POSTGRES_PASSWORD=changeme

# Redis Configuration
REDIS_PASSWORD=changeme

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_HOURS=24

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Default Admin User (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_USERNAME=admin

# Environment (set to "production" to disable OpenAPI docs)
ENV=development

# Encryption Keys (REQUIRED for production — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# If unset, keys are derived from JWT_SECRET (NOT recommended for production)
VAULT_ENCRYPTION_KEY=
TOTP_ENCRYPTION_KEY=
