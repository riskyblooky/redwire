##############################################################################
#  RedWire — environment configuration reference
##############################################################################
#
# This file is the source of truth for every environment variable RedWire
# reads. Copy it to `.env` and fill in the values that matter for your
# deployment; anything left commented / at its default keeps the built-in
# behavior.
#
# On a fresh install, `scripts/deploy_server.sh` generates strong random
# values for the secret-bearing vars automatically (marked ▶ SCRIPT
# below). Manual configuration is fine too — just don't ship the
# `changeme` / `your-secret-key-change-in-production` placeholders to
# production.
#
# For deployment topology, ports, backups, upgrades, credential rotation,
# and common troubleshooting, see `docs/ADMIN_GUIDE.md`.
#
# Optional integrations (LDAP, SAML SSO, SMTP) are configured via the
# admin UI (Admin → Auth Settings), not env vars — those settings live
# in the `auth_settings` DB table and are encrypted at rest with
# VAULT_ENCRYPTION_KEY.
##############################################################################


# ─── Networking / domain ────────────────────────────────────────────────────

# Public hostname users hit in their browser. Written into the nginx
# server_name + used as the Let's Encrypt CN. No scheme, no path.
# Required for prod. Deploy script prompts for it on fresh install.
DOMAIN_NAME=redwire.yourdomain.com

# Email address used to register with Let's Encrypt (renewal notices +
# recovery). Only used when you opt into Certbot during deploy_server.sh.
# For internal-CA / self-signed / behind-another-proxy setups, ignore.
CERTBOT_EMAIL=admin@yourdomain.com

# Origins CORS will accept. Comma-separated, EXACT match — the browser's
# Origin header must be byte-for-byte in this list (scheme + host + port).
# Default port (443 for https, 80 for http) is omitted per the CORS spec.
# Examples:
#   Single prod domain (recommended when API is same-origin):
#     CORS_ORIGINS=https://redwire.example.com
#   Multiple:
#     CORS_ORIGINS=https://redwire.example.com,https://redwire-staging.example.com
#   Non-default port:
#     CORS_ORIGINS=https://redwire.example.com:8443
# When running behind a chain of external proxies, whatever the browser
# actually sends in `Origin` is what belongs here — see ADMIN_GUIDE.md
# troubleshooting section.
CORS_ORIGINS=https://redwire.yourdomain.com

# Frontend baked-in API URL. This value is substituted into the client JS
# bundle at BUILD time (Next.js public env). Changing it after build has
# no effect — you must rebuild the frontend image.
#
# Recommended: `/api` (path-only) so the client uses whatever origin the
# page is served from. Removes an entire class of "browser can't reach
# the backend" problems, and eliminates CORS entirely for same-origin
# calls. Requires nginx to proxy /api/* to the backend (RedWire's nginx
# already does — see nginx/conf.d/default.conf.template).
#
# Explicit URL only when the API genuinely lives on a different host:
#     NEXT_PUBLIC_API_URL=https://api.redwire.example.com
NEXT_PUBLIC_API_URL=/api

# External URLs the backend uses when it needs to construct absolute
# links, most commonly SAML AssertionConsumerService / OAuth callbacks
# and 2FA setup flows. Match the URLs users actually see in the browser.
# Required if you enable SAML.
BACKEND_URL=https://redwire.yourdomain.com/api
FRONTEND_URL=https://redwire.yourdomain.com


# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Only referenced by docker-compose to spin up the internal postgres
# service + backend connection string. Change POSTGRES_PASSWORD before
# any deployment — the default 'changeme' is well-known.
# ▶ SCRIPT auto-generates POSTGRES_PASSWORD (openssl rand -hex 32)

POSTGRES_DB=redwire
POSTGRES_USER=redwire
POSTGRES_PASSWORD=changeme

# Optional. Emits every SQL query the ORM sends to stderr — massive log
# volume, only useful for debugging. Prod default is off.
# SQL_ECHO=false


# ─── Cache / rate limiting (Redis) ──────────────────────────────────────────
# ▶ SCRIPT auto-generates REDIS_PASSWORD (openssl rand -hex 32)

REDIS_PASSWORD=changeme


# ─── Object storage (MinIO / S3) ────────────────────────────────────────────
# Evidence uploads, encrypted report artifacts, plugin assets.
# ▶ SCRIPT auto-generates MINIO_ROOT_PASSWORD (openssl rand -hex 32)

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Optional overrides — only touch if MinIO isn't the containerized default.
# MINIO_ENDPOINT=minio:9000
# MINIO_EXTERNAL_ENDPOINT=minio.example.com:9000   # If browsers need a different URL than the backend
# MINIO_BUCKET=redwire-evidence
# MINIO_SECURE=false                                # true when talking to MinIO over HTTPS


# ─── Auth / JWT ─────────────────────────────────────────────────────────────
# JWT_SECRET signs access and refresh tokens. Changing it invalidates
# every session — all users get logged out on the next request. Rotating
# it deliberately is the "log everyone out" button; leaving the default
# is a critical security hole.
# ▶ SCRIPT auto-generates JWT_SECRET (openssl rand -hex 32)
JWT_SECRET=your-secret-key-change-in-production-use-openssl-rand-hex-32

# Signing algorithm. HS256 (HMAC-SHA256) is the only supported value.
JWT_ALGORITHM=HS256

# Access token lifetime in minutes. Short — a compromised token expires
# fast. UI refreshes silently before expiry via the refresh cookie.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in hours. Long — a user who closes the browser
# stays logged in for this long before needing to re-enter credentials.
REFRESH_TOKEN_EXPIRE_HOURS=24


# ─── Encryption at rest (Fernet keys) ───────────────────────────────────────
# REQUIRED in production. Backend fails closed on startup if either key
# is missing (GHSA-pg99). Format is Fernet: 32 random bytes url-safe
# base64 encoded (44 chars ending in `=`). NOT the same as JWT_SECRET.
# Generate:
#   python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# OR (older docs sometimes show):
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# BACK THESE UP SEPARATELY FROM THE DATABASE. If you lose the key, every
# credential vault entry and every user's TOTP secret becomes
# irrecoverable — there's no admin override for lost-key decrypt.
# Rotating them safely requires `python rotate_encryption_keys.py`; see
# ADMIN_GUIDE.md → Credential rotation.
# ▶ SCRIPT auto-generates both keys with real Fernet values
VAULT_ENCRYPTION_KEY=
TOTP_ENCRYPTION_KEY=


# ─── Initial admin account ──────────────────────────────────────────────────
# Created on first backend startup if the users table is empty. Not used
# after that — change the admin password via the profile page.
# ▶ SCRIPT prompts for these on fresh install (blank password → random)

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme


# ─── Frontend + Node.js runtime ─────────────────────────────────────────────
# Set to `production` for prod deploys. Also toggles source-map generation
# and bundle optimization in the Next build. Set automatically by the
# prod compose file.
# NODE_ENV=production

# Node.js heap ceiling for the Next build. 2GB matches the 4GB-VPS
# assumption baked into the frontend Dockerfile (max-old-space-size=2048).
# Raise if your build target has more RAM and you're seeing OOM.
# NODE_OPTIONS=--max-old-space-size=2048


# ─── Upload + import limits ─────────────────────────────────────────────────
# All are OPTIONAL. Defaults are shown; uncomment + tune if you regularly
# hit them. Values are bytes unless noted.

# Assets CSV / spreadsheet import
# ASSET_IMPORT_MAX_BYTES=26214400            # 25 MiB
# ASSET_IMPORT_MAX_ROWS=50000

# Engagement transfer (export/import zip)
# ENGAGEMENT_IMPORT_MAX_ARCHIVE_BYTES=209715200      # 200 MiB
# ENGAGEMENT_IMPORT_MAX_COMPRESSION_RATIO=100        # zip-bomb defense (GHSA-f826)
# ENGAGEMENT_IMPORT_REQUIRE_DIGEST=true              # GHSA-vwgf. Set false ONLY to import pre-1.2 archives, then set back.

# Scanner output imports (Nessus, Nmap, etc.)
# SCANNER_IMPORT_MAX_BYTES=                          # empty = unlimited

# Report export (evidence bundled inline)
# REPORT_EXPORT_MAX_EVIDENCE_BYTES=52428800          # 50 MiB

# User profile photo
# PROFILE_PHOTO_MAX_BYTES=5242880                    # 5 MiB


# ─── LDAP login ─────────────────────────────────────────────────────────────
# Wall-clock cap on each socket op (connect + read) during an LDAP login.
# Bounds the service bind, the user-DN search, AND the user-verify bind so
# a wedged / silent DC can't hang a login request. Applies only to login;
# the admin "Test Connection" button uses its own 10s cap. Default 15s.
# Clamped to [3, 120]. The rest of the LDAP config lives in the admin UI
# (Admin → Auth Settings) — this is only the timeout.
# LDAP_LOGIN_TIMEOUT_S=15


# ─── Automations ────────────────────────────────────────────────────────────
# Comma-separated list of domains automation "send email" actions are
# allowed to target. Empty / unset = no restriction (permissive default).
# Example: only allow internal emails:
#     AUTOMATION_EMAIL_DOMAIN_ALLOWLIST=yourcompany.com,contractor.example
# AUTOMATION_EMAIL_DOMAIN_ALLOWLIST=


# ─── Background jobs ────────────────────────────────────────────────────────
# Interval between threat-intel feed refreshes, in seconds. Default 2h.
# Lower for tighter freshness at the cost of upstream API load.
# INTEL_REFRESH_INTERVAL=7200


# ─── Plugins ────────────────────────────────────────────────────────────────
# Plugin signature verification mode:
#   off     — no signature check (default, matches how in-tree plugins ship)
#   warn    — log a warning if a plugin's signature is missing/invalid but load it
#   enforce — refuse to load unsigned or invalid-signature plugins
# PLUGIN_VERIFY=off
# PLUGIN_VERIFY_PUBKEY=                              # Ed25519 public key (PEM); required when mode is warn or enforce


# ─── MCP server (AI chatbot) ────────────────────────────────────────────────
# The in-app AI chatbot talks to the MCP sidecar container. Both defaults
# assume the compose network name resolution — override only if you're
# running MCP on a different host or port.
# MCP_SERVER_URL=http://mcp-server:3001
# MCP_PORT=3001                                      # MCP container's listen port
# REDWIRE_API_URL=http://backend:8000                # How MCP reaches the backend (internal)
