# Canonical line endings for the RedWire repo.
#
# Strategy: store everything as LF in the repo and check it out as LF in
# all working trees, regardless of OS. This works for editing on both
# Windows and WSL/Linux because modern editors and toolchains (VS Code,
# Node, Python, Docker, etc.) all handle LF on Windows.
#
# Exceptions: Windows-only scripts (.bat, .cmd, .ps1) must keep CRLF
# because cmd.exe / PowerShell will misbehave with LF.

# Default — auto-detect text, normalize to LF in the repo and on checkout
* text=auto eol=lf

# ── Source code (LF) ─────────────────────────────────────────────────
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.svg       text eol=lf
*.sql       text eol=lf

# ── Config / docs (LF) ───────────────────────────────────────────────
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf
.eslintrc*  text eol=lf
.prettierrc* text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf

# ── Shell scripts (must be LF on Linux) ──────────────────────────────
*.sh        text eol=lf
*.bash      text eol=lf
*.zsh       text eol=lf

# ── Windows-only scripts (must be CRLF) ──────────────────────────────
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# ── Binary (no conversion, never diff as text) ───────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.bmp       binary
*.tiff      binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary
*.7z        binary
*.rar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.pem       binary
*.key       binary
*.crt       binary
*.cer       binary
*.p12       binary
*.pfx       binary
*.db        binary
*.sqlite    binary
*.sqlite3   binary
